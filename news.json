async function loadNews() {
    const grid = document.getElementById('news-grid');
    try {
        const res = await fetch('../news.json');
        const data = await res.json();
        grid.innerHTML = "";

        data.forEach(item => {
            const strip = document.createElement('div');
            strip.className = 'article-strip';
            strip.innerHTML = `
                <div class="title-text">> ${item.title}</div>
                <div class="date-text">${item.date.split(' ')[0]}</div>
            `;
            strip.onclick = () => {
                document.getElementById('reader-body').innerHTML = `
                    <h2>${item.title}</h2>
                    <p style="color: #888; font-size: 0.8rem;">Source: Anime News Network</p>
                    <div class="article-body">${item.summary}...</div>
                    <a href="${item.link}" target="_blank" class="full-link">READ_FULL_STORY_AT_SOURCE</a>
                `;
                document.getElementById('reader').style.display = 'block';
            };
            grid.appendChild(strip);
        });
    } catch (e) {
        grid.innerHTML = "SYSTEM_ERROR: CORE_SYNC_REQUIRED";
    }
}
